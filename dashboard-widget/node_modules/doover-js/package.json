{
  "name": "doover-js",
  "version": "0.6.2",
  "description": "TypeScript client for Doover.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/getdoover/doover-js.git"
  },
  "homepage": "https://github.com/getdoover/doover-js#readme",
  "bugs": {
    "url": "https://github.com/getdoover/doover-js/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test:node": "mocha --exit --require tsx/cjs \"src/test/**/*.test.ts\"",
    "test:react": "mocha --exit --require global-jsdom/register --require tsx/cjs \"src/test/**/*.test.tsx\"",
    "test": "npm run test:node && npm run test:react"
  },
  "keywords": [
    "doover"
  ],
  "license": "Apache-2.0",
  "peerDependencies": {
    "@tanstack/react-query": "^5",
    "react": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.90.2",
    "@testing-library/react": "^16.1.0",
    "@types/chai": "^5.2.2",
    "@types/chai-as-promised": "^7.1.8",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/sinon": "^17.0.4",
    "chai": "^5.2.1",
    "chai-as-promised": "^8.0.2",
    "global-jsdom": "^25.0.0",
    "jsdom": "^25.0.1",
    "mocha": "^11.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sinon": "^21.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
